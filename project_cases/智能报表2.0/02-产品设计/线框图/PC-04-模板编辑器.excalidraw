    {"id":"comp-text-txt","type":"text","x":60,"y":275,"width":160,"height":40,"text":"📝 文本块\n组件类型: react-markdown\n支持 Markdown 语法\n可重复拖入多个","fontSize":10,"fontFamily":1},
    {"id":"comp-img","type":"rectangle","x":50,"y":345,"width":180,"height":80,"strokeColor":"#FAAD14","backgroundColor":"#FFFBE6","fillStyle":"solid","strokeWidth":1,"roughness":0},
