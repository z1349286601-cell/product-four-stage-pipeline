    {"id":"header","type":"text","x":330,"y":20,"width":600,"height":35,"text":"PC-04 模板编辑器 — Editor | 三栏 react-grid-layout","fontSize":24,"fontFamily":1,"textAlign":"center"},
    {"id":"topbar","type":"rectangle","x":40,"y":65,"width":1100,"height":48,"strokeColor":"#1677FF","backgroundColor":"#E6F4FF","fillStyle":"solid","strokeWidth":2,"roughness":0},
    {"id":"topbar-txt","type":"text","x":60,"y":75,"width":1000,"height":14,"text":"顶部栏: [← 返回模板列表] [模板名称: 未命名模板 ✎] [撤销 Ctrl+Z] [重做 Ctrl+Y] [🔍 预览/编辑 切换 Switch isPreview] [💾 保存→M10]","fontSize":12,"fontFamily":1},
