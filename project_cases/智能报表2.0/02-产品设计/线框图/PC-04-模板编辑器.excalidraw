    {"id":"canvas","type":"rectangle","x":255,"y":125,"width":600,"height":580,"strokeColor":"#D9D9D9","backgroundColor":"#FFFFFF","fillStyle":"solid","strokeWidth":2,"roughness":0},
    {"id":"canvas-title","type":"text","x":265,"y":135,"width":300,"height":18,"text":"画布 — react-grid-layout (12列, rowHeight=8, compactType=vertical)","fontSize":14,"fontFamily":1},
    {"id":"canvas-empty","type":"text","x":400,"y":380,"width":300,"height":40,"text":"🖼 空状态插画\n'从左侧拖拽组件开始创建报告'\n（当canvasItems.length === 0）","fontSize":12,"fontFamily":1,"textAlign":"center","strokeColor":"#9DA4B4"},
    {"id":"grid-lines","type":"text","x":265,"y":160,"width":500,"height":60,"text":"┌──────────┬──────────┬──────────┬──────────┐\n│ col 1-3  │ col 4-6  │ col 7-9  │ col 10-12│  12列网格\n│  (卡片1)  │  (卡片2)  │  (文本块1) │  (图片1)  │  拖入自动吸附\n└──────────┴──────────┴──────────┴──────────┘","fontSize":10,"fontFamily":3},
    {"id":"right-panel","type":"rectangle","x":870,"y":125,"width":270,"height":580,"strokeColor":"#D9D9D9","backgroundColor":"#FAFAFA","fillStyle":"solid","strokeWidth":2,"roughness":0},
    {"id":"right-title","type":"text","x":880,"y":135,"width":250,"height":18,"text":"属性面板 (320px)","fontSize":15,"fontFamily":1},
    {"id":"right-context","type":"text","x":880,"y":165,"width":250,"height":200,"text":"按选中组件类型切换:\n\n📊 图表卡片选中时:\n  标题: [Input]\n  图表类型: [Select]\n  数据指标: [Select]\n  维度: [Select]\n  样式: [配色▾] [图例Switch]\n  布局: x/y/w/h\n\n📝 文本块选中时:\n  [Markdown编辑区 TextArea]\n  [预览 Tab]\n\n🖼 图片选中时:\n  [预览缩略图]\n  [更换图片 Button]\n  [说明文字 Input]\n\n未选中:\n  Tab管理面板","fontSize":10,"fontFamily":1},
    {"id":"context-menu","type":"rectangle","x":500,"y":200,"width":120,"height":100,"strokeColor":"#722ED1","backgroundColor":"#F9F0FF","fillStyle":"solid","strokeWidth":1,"roughness":0},
