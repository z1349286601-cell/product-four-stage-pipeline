    {"id":"header","type":"text","x":350,"y":20,"width":500,"height":35,"text":"PC-08 用户与组织管理 — Tree+Table | 组织树+用户表联动","fontSize":24,"fontFamily":1,"textAlign":"center"},
    {"id":"left-panel","type":"rectangle","x":40,"y":65,"width":320,"height":620,"strokeColor":"#D9D9D9","backgroundColor":"#FFFFFF","fillStyle":"solid","strokeWidth":1,"roughness":0},
    {"id":"left-title","type":"text","x":55,"y":75,"width":250,"height":18,"text":"组织架构 Tree (集团→港区→区域三级)","fontSize":14,"fontFamily":1},
    {"id":"tree","type":"text","x":55,"y":105,"width":250,"height":200,"text":"▼ 🏢 集团总部\n  ├── ▶ 🏭 华南港区\n  ├── ▼ 🏭 华北港区\n  │   ├── ▶ 📍 A区域\n  │   ├── ● 📍 B区域  ← 当前选中\n  │   └── ▶ 📍 C区域\n  ├── ▶ 🏭 华东港区\n  └── ▶ 🏭 西部港区\n\n组件: Tree\n交互: 点击节点→右侧用户表过滤\n      为选中节点下的用户","fontSize":11,"fontFamily":3},
    {"id":"right-panel","type":"rectangle","x":375,"y":65,"width":765,"height":620,"strokeColor":"#D9D9D9","backgroundColor":"#FFFFFF","fillStyle":"solid","strokeWidth":1,"roughness":0},
